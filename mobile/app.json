{
  "expo": {
    "name": "Connoisseur Operator",
    "slug": "connoisseur-operator",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.connoisseur.operator",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used to scan bundle barcodes"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f172a",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      },
      "permissions": ["android.permission.CAMERA"],
      "package": "com.connoisseur.operator"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Connoisseur Operator to access your camera to scan bundle barcodes."
        }
      ]
    ]
  }
}
